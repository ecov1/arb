# Demo environment (default, fake money)
KALSHI_API_KEY_ID=your-demo-key-id-here
KALSHI_KEY="-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----"

# Production environment — set KALSHI_ENV=prod to use
# Dry-run is forced on prod unless KALSHI_LIVE_ORDERS=true
KALSHI_PROD_API_KEY_ID=your-prod-key-id-here
KALSHI_PROD_KEY="-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----"

# Switch between demo/prod:
# KALSHI_ENV=prod
# KALSHI_LIVE_ORDERS=true   # only set this when you want real orders
